---
// src/pages/index.astro
import Base from '../../layouts/Base.astro';
import Slider from '../../components/Slider.vue';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Base>
  <!-- About Us Main Section -->
  <section class="bg-gradient-to-br from-white via-gray-50 to-gray-100 text-gray-900 py-20 px-6 md:px-12 lg:px-20">
    <div class="container mx-auto text-center mb-16">
      <h1 class="text-5xl font-bold mb-6">About Us</h1>
      <p class="text-lg md:text-xl font-light">Discover more about our company, values, and commitment to our customers.</p>
    </div>

    <!-- Company Profile Section -->
    <section id="company-profile" class="mb-20 flex flex-col lg:flex-row items-center">
      <img src="../../../public/assets/logo.png" alt="Company Profile" class="w-full lg:w-1/3 rounded-lg shadow-lg transition-transform duration-300 hover:scale-105 mb-6 lg:mb-0 lg:mr-8" />
      <div class="flex-1 px-4">
        <h2 class="text-3xl font-semibold mb-4 text-center lg:text-left">Company Profile</h2>
        <p class="text-lg leading-relaxed">
          Poscar Digital Co., Ltd. is a leading smart digital system development company in Cambodia. Since its inception, we have been offering solutions such as smart school management systems, digital classrooms for distance learning, and ERP software to a wide range of clients.
        </p>
      </div>
    </section>

    <!-- Our Customers Section -->
    <section id="our-customers" class="mb-20 flex flex-col lg:flex-row items-center">
      <img src="../../../public/pp.jpg" alt="Our Customers" class="w-full lg:w-1/3 rounded-lg shadow-lg transition-transform duration-300 hover:scale-105 mb-6 lg:mb-0 lg:mr-8" />
      <div class="flex-1 px-4">
        <h2 class="text-3xl font-semibold mb-4 text-center lg:text-left">Our Customers</h2>
        <p class="text-lg leading-relaxed">
          We proudly serve a diverse range of clients, from startups to established enterprises across various industries. Our commitment to quality and innovation is evident in our clients’ successes, and we strive to build lasting partnerships based on trust and mutual growth.
        </p>
      </div>
    </section>

    <!-- Legal Section -->
    <section id="legal" class="mb-20">
      <h2 class="text-3xl font-semibold mb-12 text-center">Legal</h2>

      <!-- Privacy Policy -->
      <div class="flex flex-col lg:flex-row items-center bg-gray-100 p-8 rounded-lg shadow-lg mb-12 transition-shadow duration-300 hover:shadow-xl">
        <img src="../../../public/pp2.png" alt="Privacy Policy" class="w-full lg:w-1/3 rounded-lg shadow-lg mb-6 lg:mb-0 lg:mr-8 transition-transform duration-300 hover:scale-105" />
        <div class="flex-1 px-4">
          <h3 class="text-2xl font-semibold mb-4">Privacy Policy</h3>
          <p class="text-lg leading-relaxed mb-4">
            We are committed to protecting your privacy and ensuring that your personal information is handled responsibly. Our Privacy Policy outlines how we collect, use, and safeguard your data.
          </p>
          <a 
            href={`/${lang}/legal/privacy/`} 
            class="text-cyan-600 font-semibold hover:text-cyan-400 transition-colors duration-300"
          >
            Read Privacy Policy
          </a>
        </div>
      </div>

      <!-- Terms and Conditions -->
      <div class="flex flex-col lg:flex-row items-center bg-gray-100 p-8 rounded-lg shadow-lg transition-shadow duration-300 hover:shadow-xl">
        <img src="/path/to/terms-image.jpg" alt="Terms and Conditions" class="w-full lg:w-1/3 rounded-lg shadow-lg mb-6 lg:mb-0 lg:mr-8 transition-transform duration-300 hover:scale-105" />
        <div class="flex-1 px-4">
          <h3 class="text-2xl font-semibold mb-4">Terms and Conditions</h3>
          <p class="text-lg leading-relaxed mb-4">
            Our Terms and Conditions outline the rules and regulations for using our services and accessing our platform. Please review them to understand your rights and obligations.
          </p>
          <a 
            href={`/${lang}/legal/terms/`} 
            class="text-cyan-600 font-semibold hover:text-cyan-400 transition-colors duration-300"
          >
            Read Terms and Conditions
          </a>
        </div>
      </div>
    </section>
  </section>
</Base>
