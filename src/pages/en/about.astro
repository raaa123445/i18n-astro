---
// src/pages/index.astro
import Base from '../../layouts/Base.astro';
import Slider from '../../components/Slider.vue';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Base>
  <!-- About Us Main Section -->
  <section class="bg-white text-gray-800 py-16 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-4">About Us</h1>
        <p class="text-lg md:text-xl">Discover more about our company, values, and commitment to our customers.</p>
      </div>

      <!-- Company Profile Section -->
      <section id="company-profile" class="mb-16 flex flex-col lg:flex-row items-center">
        <img src="../../../public/assets/logo.png" alt="Company Profile" class="w-full lg:w-1/3 rounded-lg shadow-lg mb-6 lg:mb-0 lg:mr-8" />
        <div class="flex-1">
          <h2 class="text-3xl font-semibold mb-4 text-center lg:text-left">Company Profile</h2>
          <p class="text-lg mb-4">
            Poscar Digital Co., Ltd. is a leading smart digital system development company in Cambodia. It has provided smart school management system, digital classroom for distance learning, and ERP software amongst others to wide clientele since inception.
          </p>
        </div>
      </section>

      <!-- Our Customers Section -->
      <section id="our-customers" class="mb-16 flex flex-col lg:flex-row items-center">
        <img src="../../../public/pp.jpg" alt="Our Customers" class="w-full lg:w-1/3 rounded-lg shadow-lg mb-6 lg:mb-0 lg:mr-8" />
        <div class="flex-1">
          <h2 class="text-3xl font-semibold mb-4 text-center lg:text-left">Our Customers</h2>
          <p class="text-lg mb-4">
            We proudly serve a diverse range of clients, from startups to established enterprises, across various industries. Our clients’ success is a testament to our commitment to quality and innovation, and we strive to build lasting partnerships based on trust and mutual growth.
          </p>
        </div>
      </section>

      <!-- Legal Section -->
      <section id="legal" class="mb-16">
        <h2 class="text-3xl font-semibold mb-6 text-center">Legal</h2>

        <!-- Privacy Policy -->
        <div class="flex flex-col lg:flex-row items-center bg-gray-100 p-6 rounded-lg mb-8">
          <img src="../../../public/pp2.png" alt="Privacy Policy" class="w-full lg:w-1/3 rounded-lg shadow-lg mb-6 lg:mb-0 lg:mr-8" />
          <div class="flex-1">
            <h3 class="text-2xl font-semibold mb-4">Privacy Policy</h3>
            <p class="text-lg mb-4">
              We are committed to protecting your privacy and ensuring that your personal information is handled responsibly. Our Privacy Policy outlines how we collect, use, and safeguard your data.
            </p>
            <a 
              href={`/${lang}/legal/privacy/`} 
              class="text-cyan-600 font-semibold hover:text-cyan-400 transition-colors duration-300"
            >
              Read Privacy Policy
            </a>
          </div>
        </div>

        <!-- Terms and Conditions -->
        <div class="flex flex-col lg:flex-row items-center bg-gray-100 p-6 rounded-lg">
          <img src="/path/to/terms-image.jpg" alt="Terms and Conditions" class="w-full lg:w-1/3 rounded-lg shadow-lg mb-6 lg:mb-0 lg:mr-8" />
          <div class="flex-1">
            <h3 class="text-2xl font-semibold mb-4">Terms and Conditions</h3>
            <p class="text-lg mb-4">
              Our Terms and Conditions outline the rules and regulations for using our services and accessing our platform. Please review them to understand your rights and obligations.
            </p>
            <a 
            href={`/${lang}/legal/privacy/`} 
              class="text-cyan-600 font-semibold hover:text-cyan-400 transition-colors duration-300"
            >
              Read Terms and Conditions
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</Base>
