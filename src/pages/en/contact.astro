---
// src/pages/contact.astro
import Base from '../../layouts/Base.astro';
---

<Base>
  <!-- Contact Us Section -->
<section class="bg-cover bg-center bg-no-repeat text-white py-16 px-6 md:px-12 lg:px-16" style="background-image: url('../../../public/pp2.png');">
    <div class="container mx-auto text-center p-8 rounded-lg text-black">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Contact Us</h1>
      <p class="text-lg md:text-xl mb-8">We'd love to hear from you! Please fill out the form below and we'll be in touch shortly.</p>
    </div>
  </section>
  

 

  <!-- Location Map Section -->
<section class="py-16 bg-gray-100 text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-semibold mb-6">Our Location</h2>
      <p class="text-lg md:text-xl mb-8">Find us at our office in Phnom Penh, Cambodia.</p>
      <!-- Google Map Embed -->
      <div class="w-full h-screen">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3048.3501001134096!2d104.92547577370833!3d11.594652843571561!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x310953acc34f48bd%3A0xdc7731a1497fa17b!2sPOSCAR%20Digital%20Co.%2C%20Ltd.!5e1!3m2!1skm!2skh!4v1731038988468!5m2!1skm!2skh"
          class="w-full h-full"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
  </section>
  
  <!-- Contact Form Section -->
  <section class="py-16 bg-gray-100 text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto">
      <div class="max-w-lg mx-auto">
        <form action="/submit-form" method="POST" class="bg-gray-100 shadow-xl rounded-lg p-8 space-y-6">
          <div>
            <label for="name" class="block text-lg font-semibold mb-2">Name</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required 
              class="w-full px-4 py-3 rounded-lg border-gray-300 focus:border-cyan-600 focus:ring-cyan-600"
            />
          </div>
          <div>
            <label for="email" class="block text-lg font-semibold mb-2">Email</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required 
              class="w-full px-4 py-3 rounded-lg border-gray-300 focus:border-cyan-600 focus:ring-cyan-600"
            />
          </div>
          <div>
            <label for="message" class="block text-lg font-semibold mb-2">Message</label>
            <textarea 
              id="message" 
              name="message" 
              rows="4" 
              required 
              class="w-full px-4 py-3 rounded-lg border-gray-300 focus:border-cyan-600 focus:ring-cyan-600"
            ></textarea>
          </div>
          <div class="text-center">
            <button 
              type="submit" 
              class="bg-cyan-600 text-white py-3 px-6 rounded-lg text-lg font-semibold hover:bg-cyan-500 transition-colors duration-300"
            >
              Send Message
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>


   <!-- Contact Details Section -->
   <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-semibold mb-6">Our Address</h2>
      <p class="text-lg md:text-xl mb-4">
        3E:Fii Building 6th-7th Floor, Street Vimean Ahha, Kien Klaing Village, Sangkat Chroy Changva, Khan Chroy Changvar, Phnom Penh, Cambodia.
      </p>
      <p class="text-lg md:text-xl mb-4">Phone: 095 569 568 | 081 569 568</p>
      <p class="text-lg md:text-xl mb-8">Email: <a href="mailto:info@vithean.com" class="text-cyan-600">info@vithean.com</a></p>
    </div>
  </section>
</Base>