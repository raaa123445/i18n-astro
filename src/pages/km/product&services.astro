---
// src/pages/kh/products_services.astro
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Base>
  <!-- Products & Services Header Section -->
  <section class="bg-gradient-to-r from-blue-500 via-green-500 to-teal-500 text-white py-16 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">бһ•бһӣбһ·бһҸбһ•бһӣ бһ“бһ·бһ„ бһҹбҹҒбһңбһ¶бһҖбһҳбҹ’бһҳ бһҡбһ”бһҹбҹӢбһҷбһҫбһ„</h1>
      <p class="text-lg md:text-xl mb-8">бһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ–бһёбһҠбҹҶбһҺбҹ„бҹҮбһҹбҹ’бһҡбһ¶бһҷбһ…бҹ’бһ“бҹғбһ”бҹ’бһҡбһҢбһ·бһҸбһҠбҹӮбһӣбһҷбһҫбһ„бһ•бҹ’бһҸбһӣбҹӢбһҮбһјбһ“бһҠбһҫбһҳбҹ’бһ”бһёбһӮбһ¶бҹҶбһ‘бҹ’бһҡбһ…бҹҶбһ–бҹ„бҹҮбһҸбһҳбҹ’бһҡбһјбһңбһҖбһ¶бһҡбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбҹ”</p>
    </div>
  </section>

  <!-- Products & Services Details Section -->
  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto">
      
      <!-- Education Section -->
      <div class="mb-16 text-center">
        <h2 class="text-3xl md:text-4xl font-semibold mb-6">бһҖбһ¶бһҡбһўбһ”бҹӢбһҡбҹҶ</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">бһҗбҹ’бһ“бһ¶бһҖбҹӢбһҖбһ»бһҳбһ¶бһҡ & бһҗбҹ’бһ“бһ¶бһҖбҹӢ K12</h3>
            <p class="text-lg mb-4">бһ•бҹ’бһҸбһӣбҹӢбһҖбһ¶бһҡбһўбһ”бҹӢбһҡбҹҶбһӮбһ»бһҺбһ—бһ¶бһ–бһ…бһ¶бһ”бҹӢбһ–бһёбһҗбҹ’бһ“бһ¶бһҖбҹӢбһҖбһ»бһҳбһ¶бһҡбһҠбһӣбҹӢбһҗбҹ’бһ“бһ¶бһҖбҹӢ K12бҹ”</p>
            <a 
              href="https://wikischool.asia" 
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              бһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ”бһ“бҹ’бһҗбҹӮбһҳ
            </a>
          </div>
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">бһҠбҹҶбһҺбҹ„бҹҮбһҹбҹ’бһҡбһ¶бһҷбһҹбһ¶бһҖбһӣбһңбһ·бһ‘бҹ’бһҷбһ¶бһӣбҹҗбһҷ</h3>
            <p class="text-lg mb-4">бһҮбҹҶбһҡбһ»бһүбһҖбһ¶бһҡбһўбһ”бҹӢбһҡбҹҶбһҗбҹ’бһ“бһ¶бһҖбҹӢбһўбһ“бһ»бһңбһ·бһ‘бҹ’бһҷбһ¶бһӣбҹҗбһҷбһҮбһ¶бһҳбһҪбһҷбһҠбҹҶбһҺбҹ„бҹҮбһҹбҹ’бһҡбһ¶бһҷбһ‘бҹҶбһ“бһҫбһ”бҹ”</p>
            <a 
              href="/products_services/university" 
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              бһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ”бһ“бҹ’бһҗбҹӮбһҳ
            </a>
          </div>
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">бһҖбһ¶бһҡбһ…бһ»бҹҮбһҲбҹ’бһҳбҹ„бҹҮ</h3>
            <p class="text-lg mb-4">бһ”бһ„бҹ’бһҖбһ¶бһҡбһ…бҹҶбһҺбһ¶бһҷбһ–бҹҒбһӣбһҮбһ¶бһҳбһҪбһҷбһ“бһ№бһ„бһҠбҹҶбһҺбҹ„бҹҮбһҹбҹ’бһҡбһ¶бһҷбһҖбһ¶бһҡбһ…бһ»бҹҮбһҲбҹ’бһҳбҹ„бҹҮбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһңбһ·бһ‘бҹ’бһҷбһ¶бһҹбҹ’бһҗбһ¶бһ“бҹ”</p>
            <a 
              href="/products_services/enrollment" 
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              бһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ”бһ“бҹ’бһҗбҹӮбһҳ
            </a>
          </div>
        </div>
      </div>

      <!-- Enterprise Section -->
      <div class="mb-16 text-center">
        <h2 class="text-3xl md:text-4xl font-semibold mb-6">бһҹбһ бһӮбҹ’бһҡбһ¶бһҹ</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">бһ‘бҹҶбһ–бҹҗбһҡбһңбһ·бһ’бһ¶бһ“</h3>
            <p class="text-lg mb-4">бһңбҹҒбһ‘бһ·бһҖбһ¶бһ‘бһ¶бҹҶбһ„бһҹбҹ’бһҡбһ»бһ„бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҖбһ¶бһҡбһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҹбһ бһӮбҹ’бһҡбһ¶бһҹбҹ”</p>
            <a 
              href="https://vithean.com" 
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              бһ…бһјбһӣбһҳбһҫбһӣбһңбһ·бһ’бһ¶бһ“
            </a>
          </div>
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">бһ…бҹ’бһ”бһ¶бһ”бҹӢбһ…бһјбһӣ/бһҖбһ¶бһҸ/бһ§бһ”бһҖбһҡбһҺбҹҚ</h3>
            <p class="text-lg mb-4">бһ§бһ”бһҖбһҡбһҺбҹҚбһ“бһ·бһ„бһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҖбһ¶бһҡбһ…бһјбһӣбҹ”</p>
            <a 
              href="/products_services/attendance" 
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              бһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ”бһ“бҹ’бһҗбҹӮбһҳ
            </a>
          </div>
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">бһҠбҹҶбһҺбҹ„бҹҮбһҹбҹ’бһҡбһ¶бһҷбһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҳбһ“бһ»бһҹбҹ’бһҹбһ’бһ“бһ’бһ¶бһ“</h3>
            <p class="text-lg mb-4">бһ”бһ„бҹ’бһҖбһҫбһ“бһҖбһ¶бһҡбһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҳбһ“бһ»бһҹбҹ’бһҹбһ’бһ“бһ’бһ¶бһ“бһҮбһ¶бһҳбһҪбһҷбһ“бһ№бһ„бһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһҶбҹ’бһӣбһ¶бһҸбҹ”</p>
            <a 
              href="/products_services/hrm" 
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              бһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ”бһ“бҹ’бһҗбҹӮбһҳ
            </a>
          </div>
        </div>
      </div>

      <!-- Custom Solution Section -->
      <div class="mb-16 text-center">
        <h2 class="text-3xl md:text-4xl font-semibold mb-6">бһҠбҹҶбһҺбҹ„бҹҮбһҹбҹ’бһҡбһ¶бһҷбһҸбһ¶бһҳбһҸбһҳбҹ’бһҡбһјбһңбһҖбһ¶бһҡ</h2>
        <div class="grid grid-cols-1 md:grid-cols-1 lg:grid-cols-1 gap-8">
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">бһҠбҹҶбһҺбҹ„бҹҮбһҹбҹ’бһҡбһ¶бһҷбһҸбһ¶бһҳбһҸбһҳбҹ’бһҡбһјбһңбһҖбһ¶бһҡ</h3>
            <p class="text-lg mb-4">бһҠбҹҶбһҺбҹ„бҹҮбһҹбҹ’бһҡбһ¶бһҷбһ”бһ»бһӮбҹ’бһӮбһӣбһ“бһёбһҷбһҖбһҳбҹ’бһҳбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҸбһҳбҹ’бһҡбһјбһңбһҖбһ¶бһҡбһ–бһ·бһҹбҹҒбһҹбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбҹ”</p>
            <a 
              href="/products_services/custom_solutions" 
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              бһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ”бһ“бҹ’бһҗбҹӮбһҳ
            </a>
          </div>
        </div>
      </div>

      <!-- Outsourcing Section -->
      <div class="text-center">
        <h2 class="text-3xl md:text-4xl font-semibold mb-6">бһҹбҹҒбһңбһ¶бһҖбһҳбҹ’бһҳбһҖбҹ’бһҡбҹ…бһҹбҹ’бһҗбһ¶бһ”бҹҗбһ“</h2>
        <div class="grid grid-cols-1 md:grid-cols-1 lg:grid-cols-1 gap-8">
          <div class="bg-gray-100 shadow-lg rounded-lg p-6">
            <h3 class="text-2xl font-semibold mb-4">бһҹбҹҒбһңбһ¶бһҖбһҳбҹ’бһҳбһҖбҹ’бһҡбҹ…бһҹбҹ’бһҗбһ¶бһ”бҹҗбһ“</h3>
            <p class="text-lg mb-4">бһҠбҹҶбһҺбҹ„бҹҮбһҹбҹ’бһҡбһ¶бһҷбһ”бһҸбҹӢбһ”бҹӮбһ“бһҮбһ¶бһҖбһ¶бһҡбһӮбһ¶бҹҶбһ‘бҹ’бһҡбһҸбһ¶бһҳбһҸбһҳбҹ’бһҡбһјбһңбһҖбһ¶бһҡбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбҹ”</p>
            <a 
              href="/products_services/outsourcing" 
              class="text-blue-600 font-semibold hover:text-blue-400 transition-colors duration-300"
            >
              бһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ”бһ“бҹ’бһҗбҹӮбһҳ
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>
</Base>
