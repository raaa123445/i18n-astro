---
// src/pages/index.astro
import Base from '../../layouts/Base.astro';
import Slider from '../../components/Slider.vue';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Base>
  <!-- бһ”бһ‘бһ”бһ„бҹ’бһ бһ¶бһүбһ–бһёбһҖбҹ’бһҡбһ»бһҳбһ бҹҠбһ»бһ“ -->
  <section class="bg-white text-gray-800 py-16 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-4">бһўбҹҶбһ–бһёбһҷбһҫбһ„</h1>
        <p class="text-lg md:text-xl">бһҹбһјбһҳбһҹбҹ’бһңбһ¶бһӮбһҳбһ“бҹҚбһҳбһҖбһҖбһ¶бһ“бҹӢбһҖбҹ’бһҡбһ»бһҳбһ бҹҠбһ»бһ“бһҡбһ”бһҹбҹӢбһҷбһҫбһ„ бһҠбһҫбһҳбҹ’бһ”бһёбһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ”бһ“бҹ’бһҗбҹӮбһҳбһўбҹҶбһ–бһёбһҖбҹ’бһҡбһ»бһҳбһ бҹҠбһ»бһ“ бһўбһҸбһ·бһҗбһ·бһҮбһ“ бһ“бһ·бһ„бһҖбһ¶бһҡбһ”бҹ’бһҸбҹҒбһҮбҹ’бһүбһ¶бһ…бһ·бһҸбҹ’бһҸбһҡбһ”бһҹбҹӢбһҷбһҫбһ„бһ…бҹҶбһ–бҹ„бҹҮбһўбһҸбһ·бһҗбһ·бһҮбһ“бҹ”</p>
      </div>

      <!-- бһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бһҡбһјбһ”бһҖбҹ’бһҡбһ»бһҳбһ бҹҠбһ»бһ“ -->
      <section id="company-profile" class="mb-16 flex flex-col lg:flex-row items-center">
        <img src="../../../public/assets/logo.png" alt="бһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бһҡбһјбһ”бһҖбҹ’бһҡбһ»бһҳбһ бҹҠбһ»бһ“" class="w-full lg:w-1/3 rounded-lg shadow-lg mb-6 lg:mb-0 lg:mr-8" />
        <div class="flex-1">
          <h2 class="text-3xl font-semibold mb-4 text-center lg:text-left">бһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бһҡбһјбһ”бһҖбҹ’бһҡбһ»бһҳбһ бҹҠбһ»бһ“</h2>
          <p class="text-lg mb-4">
            Poscar Digital Co., Ltd. бһӮбһәбһҮбһ¶бһҖбҹ’бһҡбһ»бһҳбһ бҹҠбһ»бһ“бһҮбҹҶбһ“бһ¶бһүбһҖбҹ’бһ“бһ»бһ„бһҖбһ¶бһҡбһўбһ—бһ·бһңбһҢбҹ’бһҚбһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһҢбһёбһҮбһёбһҗбһӣбһҠжҷәж…§бһ“бҹ…бһ”бҹ’бһҡбһ‘бҹҒбһҹбһҖбһҳбҹ’бһ–бһ»бһҮбһ¶бҹ” бһҖбҹ’бһҡбһ»бһҳбһ бҹҠбһ»бһ“бһ”бһ¶бһ“бһ•бҹ’бһҸбһӣбҹӢбһҹбҹҒбһңбһ¶бһҖбһҳбҹ’бһҳбһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҹбһ¶бһӣбһ¶бһҡбҹҖбһ“бһҢбһёбһҮбһёбһҗбһӣ бһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһ”бһ„бҹ’бһҡбҹҖбһ“бһ‘бһҳбҹ’бһҡбһ„бҹӢбһ…бһҳбҹ’бһҡбһ»бҹҮ бһ“бһ·бһ„бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһё ERP бһҮбһ¶бһҠбһҫбһҳбҹ” 
          </p>
        </div>
      </section>

      <!-- бһўбһҸбһ·бһҗбһ·бһҮбһ“бһҡбһ”бһҹбҹӢбһҷбһҫбһ„ -->
      <section id="our-customers" class="mb-16 flex flex-col lg:flex-row items-center">
        <img src="../../../public/pp.jpg" alt="бһўбһҸбһ·бһҗбһ·бһҮбһ“бһҡбһ”бһҹбҹӢбһҷбһҫбһ„" class="w-full lg:w-1/3 rounded-lg shadow-lg mb-6 lg:mb-0 lg:mr-8" />
        <div class="flex-1">
          <h2 class="text-3xl font-semibold mb-4 text-center lg:text-left">бһўбһҸбһ·бһҗбһ·бһҮбһ“бһҡбһ”бһҹбҹӢбһҷбһҫбһ„</h2>
          <p class="text-lg mb-4">
            бһҷбһҫбһ„бһҳбһ¶бһ“бһўбҹҶбһҺбһҡбһӮбһ»бһҺбһҖбҹ’бһ“бһ»бһ„бһҖбһ¶бһҡбһ•бҹ’бһҸбһӣбҹӢбһҹбҹҒбһңбһ¶бһҖбһҳбҹ’бһҳбһҠбһӣбҹӢбһўбһҸбһ·бһҗбһ·бһҮбһ“бһӮбҹ’бһҡбһ”бҹӢбһ”бҹ’бһҡбһ—бҹҒбһ‘ бһҠбһјбһ…бһҮбһ¶бһҖбҹ’бһҡбһ»бһҳбһ бҹҠбһ»бһ“бһ…бһ¶бһ”бҹӢбһ•бҹ’бһҸбһҫбһҳ бһ“бһ·бһ„бһўбһ¶бһҮбһёбһңбһҖбһҳбҹ’бһҳбһҠбҹӮбһӣбһҳбһ¶бһ“бһҹбҹ’бһҗбһ·бһҸбһ·бһңбһҸбҹ’бһҸбһҳбһ¶бһ“бһҡбһ№бһ„бһҳбһ¶бҹҶ бһ–бһёбһҹбһ¶бһҒбһ¶бһ•бҹ’бһҹбҹҒбһ„бҹ—бҹ” бһҮбҹ„бһӮбһҮбҹҗбһҷбһҡбһ”бһҹбҹӢбһўбһҸбһ·бһҗбһ·бһҮбһ“бһҡбһ”бһҹбҹӢбһҷбһҫбһ„бһӮбһәбһҮбһ¶бһҹбһ¶бһҖбһҹбһ–бһ“бҹғбһҖбһ¶бһҡбһ”бҹ’бһҸбҹҒбһҮбҹ’бһүбһ¶бһ…бһ·бһҸбҹ’бһҸбһҡбһ”бһҹбҹӢбһҷбһҫбһ„бһҖбҹ’бһ“бһ»бһ„бһҖбһ¶бһҡбһ•бҹ’бһҸбһӣбҹӢбһӮбһ»бһҺбһ—бһ¶бһ– бһ“бһ·бһ„бһ“бһңбһ¶бһ“бһ»бһңбһҸбҹ’бһҸбһ“бҹҚ бһҠбҹ„бһҷбһҳбһ¶бһ“бһӮбҹ„бһӣбһ”бҹҶбһҺбһ„бһҹбһ¶бһ„бһҹбһ„бҹӢбһ‘бҹҶбһ“бһ¶бһҖбҹӢбһ‘бҹҶбһ“бһ„бһҡбһҷбҹҲбһ–бҹҒбһӣбһңбҹӮбһ„бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҖбһ¶бһҡбһҡбһёбһҖбһ…бһҳбҹ’бһҡбһҫбһ“бһҮбһ¶бһҳбһҪбһҷбһӮбҹ’бһ“бһ¶бҹ”
          </p>
        </div>
      </section>

      <!-- бһ•бҹ’бһ“бҹӮбһҖбһ…бҹ’бһ”бһ¶бһ”бҹӢ -->
      <section id="legal" class="mb-16">
        <h2 class="text-3xl font-semibold mb-6 text-center">бһ…бҹ’бһ”бһ¶бһ”бҹӢ</h2>

        <!-- бһӮбҹ„бһӣбһҖбһ¶бһҡбһҺбҹҚбһ—бһ¶бһ–бһҜбһҖбһҮбһ“ -->
        <div class="flex flex-col lg:flex-row items-center bg-gray-100 p-6 rounded-lg mb-8">
          <img src="../../../public/pp2.png" alt="бһӮбҹ„бһӣбһҖбһ¶бһҡбһҺбҹҚбһ—бһ¶бһ–бһҜбһҖбһҮбһ“" class="w-full lg:w-1/3 rounded-lg shadow-lg mb-6 lg:mb-0 lg:mr-8" />
          <div class="flex-1">
            <h3 class="text-2xl font-semibold mb-4">бһӮбҹ„бһӣбһҖбһ¶бһҡбһҺбҹҚбһ—бһ¶бһ–бһҜбһҖбһҮбһ“</h3>
            <p class="text-lg mb-4">
              бһҷбһҫбһ„бһҳбһ¶бһ“бһҖбһ¶бһҡбһ”бҹ’бһҸбҹҒбһҮбҹ’бһүбһ¶бһ…бһ·бһҸбҹ’бһҸбһҖбҹ’бһ“бһ»бһ„бһҖбһ¶бһҡбһ–бһ¶бһҡбһ—бһ¶бһ–бһҜбһҖбһҮбһ“бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖ бһ бһҫбһҷбһ’бһ¶бһ“бһ¶бһҗбһ¶бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бһ•бҹ’бһ‘бһ¶бһӣбҹӢбһҒбҹ’бһӣбһҪбһ“бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһҷбҹүбһ¶бһ„бһҹбҹҶбһҒбһ¶бһ“бҹӢбҹ” бһӮбҹ„бһӣбһҖбһ¶бһҡбһҺбҹҚбһ—бһ¶бһ–бһҜбһҖбһҮбһ“бһҡбһ”бһҹбҹӢбһҷбһҫбһ„бһ“бһ·бһҷбһ¶бһҷбһўбҹҶбһ–бһёбһҡбһ”бҹҖбһ”бһҠбҹӮбһӣбһҷбһҫбһ„бһ”бҹ’бһҡбһҳбһјбһӣ бһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢ бһ“бһ·бһ„бһҖбһ¶бһҡбһ–бһ¶бһҡбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбҹ”
            </p>
            <a 
              href={`/${lang}/legal/privacy/`} 
              class="text-cyan-600 font-semibold hover:text-cyan-400 transition-colors duration-300"
            >
              бһўбһ¶бһ“бһӮбҹ„бһӣбһҖбһ¶бһҡбһҺбҹҚбһ—бһ¶бһ–бһҜбһҖбһҮбһ“
            </a>
          </div>
        </div>

        <!-- бһӣбҹҗбһҖбҹ’бһҒбһҒбһҺбҹ’бһҢ бһ“бһ·бһ„ бһўбҹ’бһ“бһҖбһҸбҹҶбһҺбһ¶бһ„ -->
        <div class="flex flex-col lg:flex-row items-center bg-gray-100 p-6 rounded-lg">
          <img src="/path/to/terms-image.jpg" alt="бһӣбҹҗбһҖбҹ’бһҒбһҒбһҺбҹ’бһҢ бһ“бһ·бһ„ бһўбҹ’бһ“бһҖбһҸбҹҶбһҺбһ¶бһ„" class="w-full lg:w-1/3 rounded-lg shadow-lg mb-6 lg:mb-0 lg:mr-8" />
          <div class="flex-1">
            <h3 class="text-2xl font-semibold mb-4">бһӣбҹҗбһҖбҹ’бһҒбһҒбһҺбҹ’бһҢ бһ“бһ·бһ„ бһўбҹ’бһ“бһҖбһҸбҹҶбһҺбһ¶бһ„</h3>
            <p class="text-lg mb-4">
              бһӣбҹҗбһҖбҹ’бһҒбһҒбһҺбҹ’бһҢ бһ“бһ·бһ„ бһўбҹ’бһ“бһҖбһҸбҹҶбһҺбһ¶бһ„бһҡбһ”бһҹбҹӢбһҷбһҫбһ„бһ”бһүбҹ’бһҮбһ¶бһҖбҹӢбһ–бһёбһ”бһ‘бһ”бһүбҹ’бһҮбһ¶бһ“бһ·бһ„бһңбһ·бһ’бһ¶бһ“бһҖбһ¶бһҡбһҺбҹҚбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҖбһ¶бһҡбһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢбһҹбҹҒбһңбһ¶бһҖбһҳбҹ’бһҳбһҡбһ”бһҹбҹӢбһҷбһҫбһ„ бһ“бһ·бһ„бһҖбһ¶бһҡбһ…бһјбһӣбһ”бҹ’бһҡбһҫбһ”бҹ’бһҡбһ¶бһҹбҹӢбһңбҹҒбһ‘бһ·бһҖбһ¶бһҠбҹ„бһҷбһўбһҸбһ·бһҗбһ·бһҮбһ“бҹ” бһҹбһјбһҳбһ–бһ·бһ“бһ·бһҸбҹ’бһҷбһҖбһ¶бһҡбһ…бҹ’бһ”бһ¶бһ”бҹӢбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһҖбһ¶бһҡбһҷбһӣбҹӢбһҠбһ№бһ„бһўбҹҶбһ–бһёбһҹбһ·бһ‘бһ·бҹ’бһ’ бһ“бһ·бһ„ бһҖбһ¶бһҸбһ–бҹ’бһңбһҖбһ·бһ…бҹ’бһ…бһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбҹ”
            </p>
            <a 
              href={`/${lang}/legal/privacy/`} 
              class="text-cyan-600 font-semibold hover:text-cyan-400 transition-colors duration-300"
            >
              бһўбһ¶бһ“бһӣбҹҗбһҖбҹ’бһҒбһҒбһҺбҹ’бһҢ бһ“бһ·бһ„ бһўбҹ’бһ“бһҖбһҸбҹҶбһҺбһ¶бһ„
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</Base>
