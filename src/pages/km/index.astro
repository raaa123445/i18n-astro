---
// src/pages/index.astro
import Base from '../../layouts/Base.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Base>
  <!-- Welcome Section -->
  <section class="bg-gradient-to-r from-cyan-500 via-purple-500 to-pink-500 text-white py-16">
    <div class="container mx-auto text-center">
      <h1 class="text-5xl font-extrabold mb-4">бһҹбһјбһҳбһҹбҹ’бһңбһ¶бһӮбһҳбһ“бҹҚбһҳбһҖбһҖбһ¶бһ“бҹӢ Poscar</h1>
      <p class="text-xl mb-8">бһҳбһ·бһҸбҹ’бһҸбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбһҖбҹ’бһ“бһ»бһ„бһҖбһ¶бһҡбһ•бҹ’бһҸбһӣбҹӢбһҠбҹҶбһҺбҹ„бҹҮбһҹбҹ’бһҡбһ¶бһҷбһ”бҹ’бһҡбһҖбһ”бһҠбҹ„бһҷбһ—бһ¶бһ–бһ…бҹ’бһ“бҹғбһ”бҹ’бһҡбһҢбһ·бһҸ</p>
      <a 
        href="/products_services" 
        class="bg-cyan-600 text-white py-3 px-6 rounded-lg text-lg font-semibold hover:bg-cyan-500 transition-colors duration-300"
      >
        бһҹбҹ’бһңбҹӮбһ„бһҡбһҖбһҹбҹҒбһңбһ¶бһҖбһҳбҹ’бһҳбһҡбһ”бһҹбҹӢбһҷбһҫбһ„
      </a>
    </div>
  </section>

  <!-- About Us Section -->
  <section class="py-16 bg-white text-gray-800">
    <div class="container mx-auto text-center">
      <h2 class="text-4xl font-semibold mb-6">бһўбҹҶбһ–бһёбһҷбһҫбһ„</h2>
      <p class="text-lg mb-8">бһҹбһјбһҳбһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ–бһёбһҠбҹҶбһҺбһҫбһҡбһ“бһ·бһ„бһ‘бһҹбҹ’бһҹбһ“бһҖбһ·бһ…бҹ’бһ…бһҡбһ”бһҹбҹӢбһҷбһҫбһ„бҹ”</p>
      <a 
        href="/about/" 
        class="bg-transparent border-2 border-cyan-600 text-cyan-600 py-3 px-6 rounded-lg text-lg font-semibold hover:bg-cyan-600 hover:text-white transition-colors duration-300"
      >
        бһҹбһјбһҳбһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ”бһ“бҹ’бһҗбҹӮбһҳ
      </a>
    </div>
  </section>

  <!-- Featured Products & Services Section -->
  <section class="py-16 bg-gray-100">
    <div class="container mx-auto text-center">
      <h2 class="text-4xl font-semibold mb-6">бһ•бһӣбһ·бһҸбһ•бһӣ бһ“бһ·бһ„бһҹбҹҒбһңбһ¶бһҖбһҳбҹ’бһҳбһҠбҹӮбһӣбһҳбһ¶бһ“бһӣбһҖбҹ’бһҒбһҺбҹҲбһ–бһ·бһҹбҹҒбһҹ</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Example of Product/Service Card -->
        <div class="bg-white shadow-xl rounded-lg p-6">
          <h3 class="text-2xl font-semibold mb-4">бһҳбһӮбҹ’бһӮбһ»бһ‘бҹҒбһҹбһҖбҹҚбһҖбһ»бһҳбһ¶бһҡ бһ“бһ·бһ„ K12</h3>
          <p class="text-lg mb-4">бһ•бҹ’бһҸбһӣбҹӢбһҖбһ¶бһҡбһўбһ”бҹӢбһҡбҹҶбһӮбһ»бһҺбһ—бһ¶бһ–бһ–бһёбһҗбҹ’бһ“бһ¶бһҖбҹӢбһҳбһ»бһ“бһҹбһ¶бһӣбһ¶бһҠбһӣбҹӢбһҗбҹ’бһ“бһ¶бһҖбҹӢK12бҹ”</p>
          <a 
            href="/products_services" 
            class="text-cyan-600 font-semibold hover:text-cyan-400 transition-colors duration-300"
          >
            бһҹбһјбһҳбһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ”бһ“бҹ’бһҗбҹӮбһҳ
          </a>
        </div>
        <div class="bg-white shadow-xl rounded-lg p-6">
          <h3 class="text-2xl font-semibold mb-4">бһҠбҹҶбһҺбҹ„бҹҮбһҹбҹ’бһҡбһ¶бһҷбһҹбһ¶бһҖбһӣбһңбһ·бһ‘бҹ’бһҷбһ¶бһӣбҹҗбһҷ</h3>
          <p class="text-lg mb-4">бһ”бһүбҹ’бһҮбһјбһ“бһңбһ·бһҹбҹҗбһҷбһҖбһ¶бһҡбһўбһ”бҹӢбһҡбҹҶбһҒбҹ’бһ–бһҹбҹӢбһҠбҹ„бһҷбһҳбһ¶бһ“бһҠбҹҶбһҺбҹ„бҹҮбһҹбҹ’бһҡбһ¶бһҷбһҠбҹӮбһӣбһҳбһ¶бһ“бһ…еҲӣж–°бһ…бһӣбһ“бҹ”</p>
          <a 
            href="/products_services" 
            class="text-cyan-600 font-semibold hover:text-cyan-400 transition-colors duration-300"
          >
            бһҹбһјбһҳбһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ”бһ“бҹ’бһҗбҹӮбһҳ
          </a>
        </div>
        <div class="bg-white shadow-xl rounded-lg p-6">
          <h3 class="text-2xl font-semibold mb-4">бһҠбҹҶбһҺбҹ„бҹҮбһҹбҹ’бһҡбһ¶бһҷHRM</h3>
          <p class="text-lg mb-4">бһ•бҹ’бһӣбһ¶бһҹбҹӢбһ”бҹ’бһҸбһјбһҡбһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһ’бһ“бһ’бһ¶бһ“бһҳбһ“бһ»бһҹбҹ’бһҹбһҮбһ¶бһҳбһҪбһҷбһ”бһ…бҹ’бһ…бҹҒбһҖбһңбһ·бһ‘бҹ’бһҷбһ¶бһҠбҹӮбһӣбһҳбһ¶бһ“бһ—бһ¶бһ–бһҶбҹ’бһӣбһ¶бһҸбһңбҹғбҹ”</p>
          <a 
            href="/products_services" 
            class="text-cyan-600 font-semibold hover:text-cyan-400 transition-colors duration-300"
          >
            бһҹбһјбһҳбһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ”бһ“бҹ’бһҗбҹӮбһҳ
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action Section -->
  <section class="py-16 bg-cyan-600 text-white text-center">
    <div class="container mx-auto">
      <h2 class="text-3xl font-semibold mb-4">бһ‘бҹҶбһ“бһ¶бһҖбҹӢбһ‘бҹҶбһ“бһ„бһҮбһ¶бһҳбһҪбһҷбһҷбһҫбһ„</h2>
      <p class="text-xl mb-6">бһҳбһ¶бһ“бһҹбҹҶбһҺбһҪбһҡбһ¬бһҸбҹ’бһҡбһјбһңбһҖбһ¶бһҡбһҮбҹҶбһ“бһҪбһҷ? бһҷбһҫбһ„бһ“бҹ…бһ‘бһёбһ“бҹҒбҹҮбһҠбһҫбһҳбҹ’бһ”бһёбһҮбһҪбһҷбһўбҹ’бһ“бһҖ!</p>
      <a 
        href={`/${lang}/contact/`} 
        class="bg-white text-cyan-600 py-3 px-8 rounded-lg text-lg font-semibold hover:bg-cyan-600 hover:text-white transition-colors duration-300"
      >
        бһ‘бҹҶбһ“бһ¶бһҖбҹӢбһ‘бҹҶбһ“бһ„бһҷбһҫбһ„
      </a>
    </div>
  </section>
</Base>
