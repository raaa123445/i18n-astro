---
// src/pages/contact.kh.astro
import Base from '../../layouts/Base.astro';
---

<Base>
  <!-- Contact Us Section -->
  <section class="bg-cover bg-center bg-no-repeat text-white py-16 px-6 md:px-12 lg:px-16" style="background-image: url('../../../public/pp2.png');">
    <div class="container mx-auto text-center">
      <h1 class="text-3xl md:text-4xl font-semibold mb-6">ទំនាក់ទំនង​មក​ពួក​យើង</h1>
      <p class="text-lg md:text-xl mb-8">យើង​សោត​រីករាយ​ដែល​បាន​ស្ដាប់​ពី​អ្នក! សូម​បំពេញ​ទម្រង់​ខាងក្រោម ហើយ​យើង​នឹង​ទាក់ទង​មក​អ្នក​វេលា​ឆាប់ៗនេះ។</p>
    </div>
  </section>

  <!-- Location Map Section -->
  <section class="py-16 bg-gray-100 text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-semibold mb-6">ទីតាំង​របស់​ពួក​យើង</h2>
      <p class="text-lg md:text-xl mb-8">ស្វែងរក​ពួក​យើង​នៅ​ការិយាល័យ​ក្នុងរាជធានី​ភ្នំពេញ។</p>
      <!-- Google Map Embed -->
      <div class="w-full h-screen">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3048.3501001134096!2d104.92547577370833!3d11.594652843571561!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x310953acc34f48bd%3A0xdc7731a1497fa17b!2sPOSCAR%20Digital%20Co.%2C%20Ltd.!5e1!3m2!1skm!2skh!4v1731038988468!5m2!1skm!2skh"
          class="w-full h-full"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="py-16 bg-gray-100 text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto">
      <div class="max-w-lg mx-auto">
        <form action="/submit-form" method="POST" class="bg-gray-100 shadow-xl rounded-lg p-8 space-y-6">
          <div>
            <label for="name" class="block text-lg font-semibold mb-2">ឈ្មោះ</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required 
              class="w-full px-4 py-3 rounded-lg border-gray-300 focus:border-cyan-600 focus:ring-cyan-600"
            />
          </div>
          <div>
            <label for="email" class="block text-lg font-semibold mb-2">អ៊ីមែល</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required 
              class="w-full px-4 py-3 rounded-lg border-gray-300 focus:border-cyan-600 focus:ring-cyan-600"
            />
          </div>
          <div>
            <label for="message" class="block text-lg font-semibold mb-2">សារ</label>
            <textarea 
              id="message" 
              name="message" 
              rows="4" 
              required 
              class="w-full px-4 py-3 rounded-lg border-gray-300 focus:border-cyan-600 focus:ring-cyan-600"
            ></textarea>
          </div>
          <div class="text-center">
            <button 
              type="submit" 
              class="bg-cyan-600 text-white py-3 px-6 rounded-lg text-lg font-semibold hover:bg-cyan-500 transition-colors duration-300"
            >
              ផ្ញើសារ
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Contact Details Section -->
  <section class="py-16 bg-white text-gray-800 px-6 md:px-12 lg:px-16">
    <div class="container mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-semibold mb-6">អាស័យដ្ឋាន​របស់​ពួក​យើង</h2>
      <p class="text-lg md:text-xl mb-4">
        អគារ 3E:Fii ជាន់ទី 6 និង 7 ផ្លូវវិមានអាហា ភូមិច្រោយខាងគោ សង្កាត់ច្រោយចង្វារ ខណ្ឌច្រោយចង្វារ រាជធានីភ្នំពេញ ប្រទេសកម្ពុជា។
      </p>
      <p class="text-lg md:text-xl mb-4">ទូរស័ព្ទ: 095 569 568 | 081 569 568</p>
      <p class="text-lg md:text-xl mb-8">អ៊ីមែល: <a href="mailto:info@vithean.com" class="text-cyan-600">info@vithean.com</a></p>
    </div>
  </section>
</Base>
