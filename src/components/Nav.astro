---
import LanguagePicker from '../components/LanguagePicker.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<ul class="sticky top-0 flex items-center justify-between bg-white bg-opacity-90 backdrop-blur-lg text-gray-800 px-4 py-3 md:px-8 shadow-lg border-b border-gray-200 z-10">
  <!-- Logo and Company Name as a Link to the Homepage -->
  <li class="flex items-center space-x-2">
    <a href={`/${lang}/`} class="flex items-center space-x-2">
      <img 
        src="../../../public/assets/lolo1.png" 
        alt="Company Logo" 
        class="w-22 h-12 rounded-full transition-transform duration-200 hover:scale-110"
      />
      <span class="text-xl font-bold bg-gradient-to-r from-cyan-500 via-blue-500 to-purple-500 bg-clip-text text-transparent hover:from-purple-500 hover:to-cyan-500 transition-colors duration-200">
        
      </span>
    </a>
  </li>  

  <!-- Hamburger Icon for Mobile -->
  <button 
    class="md:hidden text-gray-800 focus:outline-none transition-transform duration-200 hover:scale-110"
    aria-label="Toggle Navigation"
    id="menu-toggle"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
  </button>

  <!-- Menu Items -->
  <div id="nav-links" class="hidden md:flex flex-col md:flex-row items-center mt-4 md:mt-0 transition-all duration-300 space-y-4 md:space-y-0 md:space-x-6">
    <!-- Close Button (for Mobile Menu) -->
    <button id="menu-close" class="absolute top-3 right-4 text-gray-700 md:hidden">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <!-- Home Link -->
    <a 
      href={`/${lang}/`} 
      class="text-gray-700 font-medium px-3 py-2 rounded-md transition duration-200 hover:bg-cyan-100 hover:text-cyan-600 focus:bg-cyan-100"
    >
      {t('nav.home')}
    </a>

    <!-- Products & Services with Mega Menu -->
    <div class="relative group">
      <a 
        href="#" 
        class="text-gray-700 font-medium px-3 py-2 rounded-md transition duration-200 hover:bg-cyan-100 hover:text-cyan-600 focus:bg-cyan-100"
      >
        {t('nav.products_services')}
      </a>
      <!-- Mega Menu -->
      <div class="absolute hidden group-hover:flex bg-white shadow-lg p-5 rounded-lg w-72 left-0 top-full mt-2 transition-all duration-200 opacity-0 group-hover:opacity-100 z-20 border border-gray-200">
        <div class="grid grid-cols-2 gap-6">
          <div>
            <h3 class="text-sm font-semibold text-gray-600 mb-2">{t('nav.education')}</h3>
            <ul class="space-y-1">
              <li><a href="https://wikischool.asia" class="text-cyan-500 hover:text-cyan-700 transition">{t('nav.kindergarten_k12')}</a></li>
              <li><a href="#" class="text-cyan-500 hover:text-cyan-700 transition">{t('nav.university_solution')}</a></li>
              <li><a href="#" class="text-cyan-500 hover:text-cyan-700 transition">{t('nav.enrollment')}</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-600 mb-2">{t('nav.enterprise')}</h3>
            <ul class="space-y-1">
              <li><a href="https://vithean.com" class="text-cyan-500 hover:text-cyan-700 transition">{t('nav.vithean_page')}</a></li>
              <li><a href="#" class="text-cyan-500 hover:text-cyan-700 transition">{t('nav.attendance_card_device')}</a></li>
              <li><a href="#" class="text-cyan-500 hover:text-cyan-700 transition">{t('nav.hrm_solution')}</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- About Us Link with Dropdown -->
    <div class="relative group">
      <a 
        href={`/${lang}/about/`} 
        class="text-gray-700 font-medium px-3 py-2 rounded-md transition duration-200 hover:bg-cyan-100 hover:text-cyan-600 focus:bg-cyan-100"
      >
        {t('nav.about')}
      </a>
      <div class="absolute hidden group-hover:flex bg-white shadow-lg p-4 rounded-lg w-60 left-0 top-full mt-2 transition-all duration-200 opacity-0 group-hover:opacity-100 z-20 border border-gray-200">
        <ul class="space-y-1">
          <li><a href="#" class="text-cyan-500 hover:text-cyan-700 transition">{t('nav.company_profile')}</a></li>
          <li><a href="#" class="text-cyan-500 hover:text-cyan-700 transition">{t('nav.our_customers')}</a></li>
          <li class="relative group">
            <a href="#" class="text-cyan-500 hover:text-cyan-700 transition">{t('nav.legal')}</a>
            <div class="absolute hidden group-hover:flex bg-white shadow-lg p-4 rounded-lg w-40 left-full top-0 mt-0 transition-all duration-200 opacity-0 group-hover:opacity-100 border border-gray-200">
              <ul class="space-y-1">
                <li><a href="#" class="text-cyan-500 hover:text-cyan-700 transition">{t('nav.privacy')}</a></li>
                <li><a href="#" class="text-cyan-500 hover:text-cyan-700 transition">{t('nav.terms_conditions')}</a></li>
              </ul>
            </div>
          </li>
        </ul>
      </div>
    </div>

    <!-- Blogs Link -->
    <a 
      href={`/${lang}/blogs/`} 
      class="text-gray-700 font-medium px-3 py-2 rounded-md transition duration-200 hover:bg-cyan-100 hover:text-cyan-600 focus:bg-cyan-100"
    >
      {t('nav.blogs')}
    </a>

    <!-- Contact Us Link -->
    <a 
      href={`/${lang}/contact/`} 
      class="text-gray-700 font-medium px-3 py-2 rounded-md transition duration-200 hover:bg-cyan-100 hover:text-cyan-600 focus:bg-cyan-100"
    >
      {t('nav.contact_us')}
    </a>

    <!-- Language Picker -->
    <div class="ml-3">
      <LanguagePicker />
    </div>
  </div>
</ul>

<!-- Inline JavaScript to Handle Toggle -->
<script>
  const menuToggle = document.getElementById('menu-toggle');
  const navLinks = document.getElementById('nav-links');
  const menuClose = document.getElementById('menu-close');

  menuToggle.addEventListener('click', function() {
    // Toggle the visibility of the menu
    navLinks.classList.toggle('hidden');

    // Center the menu when it's displayed
    if (!navLinks.classList.contains('hidden')) {
      navLinks.classList.add('flex', 'items-center', 'justify-center', 'absolute', 'top-0', 'left-0', 'w-full', 'h-screen', 'bg-white', 'z-20');
    } else {
      navLinks.classList.remove('flex', 'items-center', 'justify-center', 'absolute', 'top-0', 'left-0', 'w-full', 'h-screen', 'bg-white', 'z-20');
    }
  });

  menuClose.addEventListener('click', function() {
    // Close the menu when the close button is clicked
    navLinks.classList.add('hidden');
    navLinks.classList.add('block', 'bg-blue-500', 'text-white', 'p-4', 'rounded-lg', 'shadow-lg', 'hover:bg-blue-700', 'transition', 'duration-300');
  });
</script>




